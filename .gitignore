# ---- 环境变量 / 密钥（切勿提交） ----
.env
.env.*
!.env.example
**/.env
**/.env.*

# ---- 依赖 ----
node_modules/
**/node_modules/

# ---- 构建产物 ----
dist/
build/
**/dist/
**/build/

# Prisma 生成代码（由 prisma generate 产出，不入库）
**/src/generated/prisma/

# ---- 日志 / 系统文件 ----
*.log
npm-debug.log*
.DS_Store
Thumbs.db
# Python 字节码缓存（部署脚本等被导入时产生）
__pycache__/
*.pyc

# ---- 工具 / 临时产物（不入库）----
# Playwright CLI 运行时产物（截图、snapshot、trace）
.playwright-cli/
**/.playwright-cli/
# 截图等验证产物输出目录
output/
# ZCode 客户端本地缓存
.zcode/
