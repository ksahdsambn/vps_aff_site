# MySQL root password used by the db container.
MYSQL_ROOT_PASSWORD=change_me_root_password

# Initial database name created by MySQL on first startup.
MYSQL_DATABASE=vps_aff_db

# Application database user consumed by the backend container.
MYSQL_USER=vps_app

# Password for MYSQL_USER.
MYSQL_PASSWORD=change_me_app_password

# JWT signing secret used by admin authentication.
# Use a strong random value of at least 32 chars: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# Initial admin username seeded into the database (only used on first run).
ADMIN_USERNAME=admin

# Initial admin password seeded into the database (only used on first run).
# REQUIRED in production; the backend container will refuse to start if unset
# when NODE_ENV=production. Please change it after first login.
ADMIN_PASSWORD=

# Optional: only for explicit local demo seeding. Runtime container initialization
# never inserts sample products.
SEED_SAMPLE_PRODUCTS=false

# Allowed browser origin(s) for backend CORS responses (comma-separated).
# "*" is REJECTED in production — specify explicit origins.
CORS_ORIGIN=http://localhost

# Number of trusted proxy hops in front of the backend
# (e.g. Cloudflare→nginx→container = 3, single nginx = 1, direct exposure = 0).
# IMPORTANT: Next.js rewrites() is itself a reverse proxy hop.
#   1Panel/OpenResty → Next.js(rewrites) → Express typically needs 2-3.
# Used for correct client-IP extraction by the rate limiter.
# Misconfiguration causes login rate-limiting to be ineffective or to misfire.
TRUST_PROXY_HOPS=1

# Prisma connection string template for local scripts and container migrations.
DATABASE_URL=mysql://vps_app:change_me_app_password@db:3306/vps_aff_db

# Backend service listen port inside the Compose network.
PORT=3000

# Host port mapped to the frontend container. Use 80 by default;
# change to another port (e.g. 8080) if port 80 is already in use.
FRONTEND_PORT=80

# ===== Next.js frontend（frontend-next）环境变量 =====

# 站点公开 URL（用于 SEO metadata / canonical / OG / sitemap / JSON-LD）。
# 必须是真实域名，消灭所有 your-domain.com 占位符。
NEXT_PUBLIC_SITE_URL=https://xmde.de

# 后端 API 地址（Next.js 服务端 fetch 与构建时 SSG 使用）。
# Docker 内默认指向 backend 服务；本地开发用 http://localhost:3000。
BACKEND_URL=http://backend:3000

# Google Search Console 验证码（meta 标签验证，可选）。
# NEXT_PUBLIC_GSC_VERIFICATION=

# Google Analytics 4 Measurement ID（可选，如 G-XXXXXXXXXX）。
# NEXT_PUBLIC_GA_ID=
