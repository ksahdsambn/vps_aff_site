# MySQL root password used by the db container.
MYSQL_ROOT_PASSWORD=change_me_root_password

# Initial database name created by MySQL on first startup.
MYSQL_DATABASE=vps_aff_db

# Application database user consumed by the backend container.
MYSQL_USER=vps_app

# Password for MYSQL_USER.
MYSQL_PASSWORD=change_me_app_password

# JWT signing secret used by admin authentication.
JWT_SECRET=replace_with_a_long_random_secret

# Allowed browser origin for backend CORS responses.
CORS_ORIGIN=http://localhost

# Prisma connection string template for local scripts and container migrations.
DATABASE_URL=mysql://vps_app:change_me_app_password@db:3306/vps_aff_db

# Backend service listen port inside the Compose network.
PORT=3000
